{
  "manifest_version": 3,
  "name": "Smart Tabs for ChatGPT",
  "version": "0.1.0",
  "description": "Adds smart tabs to ChatGPT conversations.",
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
      "js": ["dist/content.js"],
      "css": ["src/styles.css"]
    }
  ],
  "permissions": []
}